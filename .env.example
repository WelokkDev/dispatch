# This is a root-level example showing all environment variables needed
# Copy backend/.env.sample to backend/.env and frontend/.env.sample to frontend/.env

# ========================================
# BACKEND ENVIRONMENT VARIABLES
# Location: backend/.env
# ========================================

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GRADIUM_API_KEY=your_gradium_api_key_here
GRADIUM_VOICE_ID=your_voice_id_here
GRADIUM_REGION=us
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Dispatch
PORT=5001
FLASK_DEBUG=1

# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# Location: frontend/.env
# ========================================

VITE_API_BASE_URL=http://127.0.0.1:5001
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Dispatch
